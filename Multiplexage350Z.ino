// ============================================================================
// VARIABLES
// ============================================================================

int carPosition = -128;
int wordPosition = -280;

// Smoothed sensor values (updated each loop)
float oilPSI      = 0;
float battVolts    = 0;

// VSS / Speed / Trip
volatile unsigned long vssCounter = 0;  // ISR pulse counter
unsigned long lastSpeedCalc = 0;
float speedKmh   = 0;
float tripA_km   = 0;
float tripB_km   = 0;

// Simple clock (persisted to flash, drifts when powered off)
unsigned long lastClockTick = 0;
int clockH = 12, clockM = 0, clockS = 0;

// Button state
bool btnPrev         = HIGH;
unsigned long btnDown = 0;
int displayMode      = 0;   // 0 = Trip A, 1 = Trip B, 2 = Clock

// Animation frame
int frame = 0;

// Timing
unsigned long lastDisplayUpdate = 0;
unsigned long lastSave          = 0;

// ============================================================================
// ISR: count VSS pulses
// ============================================================================
void IRAM_ATTR vssISR() {
  vssCounter++;
}

// ============================================================================
// HELPERS
// ============================================================================

void tcaselect(uint8_t bus) {
  if (bus > 7) return;
  Wire.beginTransmission(MUX_Address);
  Wire.write(1 << bus);
  Wire.endTransmission();
}

// Read ADC with oversampling for noise reduction
float readADC(int pin) {
  long sum = 0;
  for (int i = 0; i < ADC_SAMPLES; i++) sum += analogRead(pin);
  return (float)sum / ADC_SAMPLES;
}

// Convert oil ADC reading to PSI using sender resistance
float oilADCtoPSI(float adc) {
  float v = adc * (3.3 / 4095.0);
  if (v >= 3.2 || v < 0.05) return 0;        // open or short circuit
  float r = OIL_R_PULLUP * v / (3.3 - v);    // sender resistance
  float psi = (r - OIL_R_MIN) / (OIL_R_MAX - OIL_R_MIN) * OIL_PSI_MAX;
  return constrain(psi, 0, OIL_PSI_MAX);
}

// ============================================================================
// FLASH PERSISTENCE (trip distances + clock)
// ============================================================================

void loadFromFlash() {
  prefs.begin("trip350z", true);  // read-only
  tripA_km = prefs.getFloat("tA", 0);
  tripB_km = prefs.getFloat("tB", 0);
  clockH   = prefs.getInt("cH", 12);
  clockM   = prefs.getInt("cM", 0);
  prefs.end();
}

void saveToFlash() {
  prefs.begin("trip350z", false);
  prefs.putFloat("tA", tripA_km);
  prefs.putFloat("tB", tripB_km);
  prefs.putInt("cH", clockH);
  prefs.putInt("cM", clockM);
  prefs.end();
}

// ============================================================================
// DISPLAY INIT + BOOT ANIMATION
// ============================================================================

void DisplayInit() {
  Wire.begin();
  for (int i = 0; i < 3; i++) {
    tcaselect(i);
    u8g2.begin();
    u8g2.clearDisplay();
  }
}

void bootAnimation() {
  carPosition = -128;
  wordPosition = -280;
  for (int i = 0; i < 3; i++) {
    tcaselect(i);
    do {
      u8g2.firstPage();
      do {
        u8g2.drawBitmap(carPosition, 0, 128 / 8, 64, car_bitmap);
        u8g2.drawBitmap(wordPosition, 0, 128 / 8, 64, word_350z);
        wordPosition++;
        carPosition++;
      } while (u8g2.nextPage());
    } while (carPosition < 150 || wordPosition < 0);
    carPosition = -128;
    wordPosition = -280;
    delay(200);
  }
  delay(1000);
}

// ============================================================================
// SETUP
// ============================================================================

void setup() {
  Serial.begin(115200);

  pinMode(OIL_PIN, INPUT);
  pinMode(VOLT_PIN, INPUT);
  pinMode(VSS_PIN, INPUT);
  pinMode(BUTTON_PIN, INPUT);  // needs external 10K pull-up to 3.3V

  attachInterrupt(digitalPinToInterrupt(VSS_PIN), vssISR, RISING);

  loadFromFlash();
  DisplayInit();
  bootAnimation();

  lastSpeedCalc    = millis();
  lastClockTick    = millis();
  lastDisplayUpdate = millis();
  lastSave         = millis();
}

// ============================================================================
// INPUT & TIMING UPDATES
// ============================================================================

void handleButton() {
  bool cur = digitalRead(BUTTON_PIN);

  // Button just released
  if (cur == HIGH && btnPrev == LOW) {
    unsigned long held = millis() - btnDown;
    if (held > 2000) {
      // Long press → reset current trip
      if (displayMode == 0) tripA_km = 0;
      else if (displayMode == 1) tripB_km = 0;
      saveToFlash();
    } else if (held > 50) {
      // Short press → cycle: Trip A → Trip B → Clock
      displayMode = (displayMode + 1) % 3;
    }
  }
  if (cur == LOW && btnPrev == HIGH) btnDown = millis();
  btnPrev = cur;
}

void updateSpeed() {
  unsigned long now = millis();
  unsigned long dt  = now - lastSpeedCalc;
  if (dt < 500) return;  // recalculate every 500 ms
  lastSpeedCalc = now;

  noInterrupts();
  unsigned long pulses = vssCounter;
  vssCounter = 0;
  interrupts();

  float km = pulses / VSS_PULSES_PER_KM;
  speedKmh = (km / dt) * 3600000.0;
  tripA_km += km;
  tripB_km += km;
}

void updateClock() {
  unsigned long now = millis();
  unsigned long dt  = now - lastClockTick;
  if (dt < 1000) return;
  lastClockTick = now;

  clockS += dt / 1000;
  while (clockS >= 60) { clockS -= 60; clockM++; }
  while (clockM >= 60) { clockM -= 60; clockH++; }
  while (clockH >= 24) { clockH -= 24; }
}

// ============================================================================
// SCREEN 0 : OIL PRESSURE GAUGE
// ============================================================================

void drawOilGauge() {
  // Read sensor BEFORE entering draw loop
  float raw = readADC(OIL_PIN);
  float psi = oilADCtoPSI(raw);
  oilPSI = oilPSI * 0.7 + psi * 0.3;  // smooth

  int barW = map(constrain((int)oilPSI, 0, (int)OIL_PSI_MAX),
                 0, (int)OIL_PSI_MAX, 0, 124);

  tcaselect(0);
  u8g2.firstPage();
  do {
    u8g2.drawBitmap(0, 0, 128 / 8, 64, gauge_outline);
    u8g2.drawBox(2, 13, barW, 10);

    // Animated turbo icon spinner
    u8g2.drawBitmap(37, 39, 16 / 8, 9, epd_bitmap_allArray[frame]);

    // Numeric value
    char buf[8];
    snprintf(buf, sizeof(buf), "%d", (int)oilPSI);
    u8g2.setFont(u8g2_font_ncenB12_tr);
    u8g2.drawStr(58, 60, buf);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(95, 60, "PSI");
  } while (u8g2.nextPage());
}

// ============================================================================
// SCREEN 1 : BATTERY VOLTAGE
// ============================================================================

void drawBatteryGauge() {
  float raw = readADC(VOLT_PIN);
  float v   = (raw / 4095.0) * 3.3 * VOLT_FACTOR;
  battVolts = battVolts * 0.7 + v * 0.3;  // smooth

  // Each segment = 1V, so 12V = 12 segments, 14.4V = ~14 segments
  int segs = constrain((int)battVolts, 0, 16);

  tcaselect(1);
  u8g2.firstPage();
  do {
    u8g2.drawBitmap(0, 0, 128 / 8, 64, battery_voltage);

    for (int i = 0; i < segs; i++) {
      u8g2.drawBox(2 + 6 * i, 13, 5, 10);
    }

    // Numeric voltage
    char buf[8];
    dtostrf(battVolts, 4, 1, buf);
    u8g2.setFont(u8g2_font_ncenB12_tr);
    u8g2.drawStr(40, 60, buf);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(100, 60, "V");
  } while (u8g2.nextPage());
}

// ============================================================================
// SCREEN 2 : TRIP COMPUTER / CLOCK
// ============================================================================

void drawTripComputer() {
  tcaselect(2);
  u8g2.firstPage();
  do {
    // Border + header divider
    u8g2.drawFrame(0, 0, 128, 64);
    u8g2.drawHLine(1, 13, 126);

    // Header label
    u8g2.setFont(u8g2_font_5x7_tr);
    if (displayMode == 0)      u8g2.drawStr(4, 10, "TRIP A");
    else if (displayMode == 1) u8g2.drawStr(4, 10, "TRIP B");
    else                       u8g2.drawStr(4, 10, "CLOCK");
    u8g2.drawStr(95, 10, "350Z");

    if (displayMode <= 1) {
      // ── Speed (large) ──
      char spd[6];
      snprintf(spd, sizeof(spd), "%3d", constrain((int)speedKmh, 0, 299));
      u8g2.setFont(u8g2_font_ncenB18_tr);
      u8g2.drawStr(10, 40, spd);
      u8g2.setFont(u8g2_font_5x7_tr);
      u8g2.drawStr(85, 40, "km/h");

      // ── Trip distance ──
      u8g2.drawHLine(1, 47, 126);
      float trip = (displayMode == 0) ? tripA_km : tripB_km;
      char dst[12];
      if (trip < 1000) dtostrf(trip, 6, 1, dst);
      else             snprintf(dst, sizeof(dst), "%6d", (int)trip);
      u8g2.setFont(u8g2_font_ncenB10_tr);
      u8g2.drawStr(15, 62, dst);
      u8g2.setFont(u8g2_font_5x7_tr);
      u8g2.drawStr(100, 62, "km");

    } else {
      // ── Clock (large) ──
      char clk[8];
      snprintf(clk, sizeof(clk), "%02d:%02d", clockH, clockM);
      u8g2.setFont(u8g2_font_ncenB18_tr);
      u8g2.drawStr(20, 40, clk);

      // ── Summary line: voltage + oil ──
      u8g2.drawHLine(1, 47, 126);
      char info[22];
      snprintf(info, sizeof(info), "%.1fV   %dPSI", battVolts, (int)oilPSI);
      u8g2.setFont(u8g2_font_5x7_tr);
      u8g2.drawStr(15, 62, info);
    }
  } while (u8g2.nextPage());
}

// ============================================================================
// MAIN LOOP
// ============================================================================

void loop() {
  unsigned long now = millis();

  handleButton();
  updateSpeed();
  updateClock();

  // Refresh displays at ~10 Hz
  if (now - lastDisplayUpdate >= 100) {
    lastDisplayUpdate = now;

    drawOilGauge();
    drawBatteryGauge();
    drawTripComputer();

    frame = (frame + 1) % 3;
  }

  // Persist trip + clock every 30 seconds
  if (now - lastSave >= 30000) {
    lastSave = now;
    saveToFlash();
  }
}
